# Keep Ghostty close to the current terminal feel during evaluation.

font-family = UbuntuMono Nerd Font
font-size = 16

theme = "TokyoNight Moon"
env = DOTFILES_TERM=ghostty

maximize = true
macos-titlebar-style = hidden
window-padding-x = 10
window-padding-y = 10
window-padding-color = background

mouse-hide-while-typing = true
