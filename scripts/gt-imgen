#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "openai>=1.82.0",
# ]
# ///

import argparse
import base64
import os
from datetime import UTC, datetime
from pathlib import Path

from openai import OpenAI


SOTA_IMAGE_MODEL = "gpt-image-1"
MODEL_CHOICES = [SOTA_IMAGE_MODEL]
SIZE_CHOICES = ["1024x1024", "1536x1024", "1024x1536", "auto"]
QUALITY_CHOICES = ["low", "medium", "high", "auto"]


def parse_args() -> argparse.Namespace:
    timestamp = datetime.now(UTC).strftime("%Y%m%dT%H%M%SZ")
    parser = argparse.ArgumentParser(
        description="Generate an image with the OpenAI Images API.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Supported models:\n"
            f"  {SOTA_IMAGE_MODEL}  SOTA OpenAI image generation model\n\n"
            "Supported sizes for gpt-image-1:\n"
            "  1024x1024   square\n"
            "  1536x1024   landscape\n"
            "  1024x1536   portrait\n"
            "  auto        let OpenAI choose\n\n"
            "Supported quality values:\n"
            "  low, medium, high, auto"
        ),
    )
    parser.add_argument(
        "--prompt",
        help="Image generation prompt. Required.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=Path(f"openai-image-{timestamp}.png"),
        help="Path to write the generated PNG. Defaults to ./openai-image-<UTC timestamp>.png.",
    )
    parser.add_argument(
        "--model",
        default=SOTA_IMAGE_MODEL,
        choices=MODEL_CHOICES,
        help=f"OpenAI image model to use. Defaults to {SOTA_IMAGE_MODEL}.",
    )
    parser.add_argument(
        "--size",
        default="1536x1024",
        choices=SIZE_CHOICES,
        help="Image size. Defaults to 1536x1024.",
    )
    parser.add_argument(
        "--quality",
        default="high",
        choices=QUALITY_CHOICES,
        help="Generation quality. Defaults to high.",
    )
    args = parser.parse_args()
    if not args.prompt:
        parser.print_help()
        raise SystemExit(2)
    return args


def main() -> None:
    args = parse_args()
    api_key = os.environ.get("OPENAI_API_KEY")
    if not api_key:
        raise SystemExit("OPENAI_API_KEY is required in the environment.")

    client = OpenAI(api_key=api_key)
    result = client.images.generate(
        model=args.model,
        prompt=args.prompt,
        size=args.size,
        quality=args.quality,
    )

    image = result.data[0]
    if not image.b64_json:
        raise SystemExit("OpenAI response did not include base64 image data.")

    args.output.parent.mkdir(parents=True, exist_ok=True)
    args.output.write_bytes(base64.b64decode(image.b64_json))
    print(f"Wrote {args.output}")


if __name__ == "__main__":
    main()
